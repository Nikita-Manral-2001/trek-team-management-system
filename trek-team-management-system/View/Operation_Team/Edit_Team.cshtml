@model TTH.Areas.Super.Data.Operation_Team.Add_Team

<div class="container mt-5">
    <h1>Edit Team Member</h1>
    <form asp-action="Edit_Team" method="post" enctype="multipart/form-data">
        <div class="row g-3">
        <input type="hidden" asp-for="Id" />
            <div class="form-group col-md-4">
                <label asp-for="EmpId"></label>
                <input asp-for="EmpId" class="form-control" />
            </div>

            <div class="form-group col-md-4">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
        </div>
            <div class="form-group col-md-4">
            <label asp-for="PhoneNo"></label>
            <input asp-for="PhoneNo" class="form-control" />
        </div>
            <div class="form-group col-md-4">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
        </div>
            <div class="form-group col-md-4">
                <label asp-for="DOB"></label>
                <input asp-for="DOB" class="form-control" type="date" />
            </div>
            <div class="form-group col-md-4">
                <label asp-for="Gender"></label>
                <select asp-for="Gender" class="form-control">
                    <option>Male</option>
                    <option>Female</option>
                    <option>Other</option>
                </select>
            </div>

            <div class="form-group col-md-6">
                <label asp-for="Cource"></label>
                <textarea class="form-control summerTextarea" asp-for="Cource" name="Cource" rows="3"></textarea>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="Education"></label>
                <textarea class="form-control summerTextarea" asp-for="Education" name="Education" rows="3"></textarea>
            </div>

            <div class="form-group col-md-4">
                <label asp-for="Position"></label>
                <input asp-for="Position" class="form-control" />
            </div>


            <div class="form-group col-md-4">
            <label asp-for="DateOfJoining"></label>
            <input asp-for="DateOfJoining" class="form-control" type="date" />
        </div>

            <div class="col-md-4">
                <label class="form-label"><b>Location</b></label>
                <select class="form-select form-select-sm" asp-for="Location" required>
                    <option value="Office Staff">Office Staff</option>
                    <option value="Field Staff">Field Staff</option>
                </select>
            </div>




            
            <div class="form-group col-md-4">
            <label>Current Photo</label>
            @if (!string.IsNullOrEmpty(Model.PhotoPath))
            {
                <img src="@Model.PhotoPath" alt="Photo" class="img-thumbnail" style="width: 100px; height: auto;">
            }
            <label asp-for="Photo"></label>
            <input asp-for="Photo" type="file" class="form-control" />
        </div>
           
            <div class="form-group col-md-4">
            <label><b>Upload Id</b></label>
            <input asp-for="Upload_Id" type="file" class="form-control-file" multiple />
            <span asp-validation-for="Upload_Id" class="text-danger"></span>
           
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
    </div>

