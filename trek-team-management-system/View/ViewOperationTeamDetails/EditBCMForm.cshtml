@using TTH.Areas.Super.Data.Operation_Team
@model TrekBaseCampManager



<div class="container my-2">
    <div class="row justify-content-center">
        <div class="col-md-12 ">
            <div class="content">
                <div id="dynamicContent">
                    <div class="card shadow">
                        <div class="card-header bg-danger text-white text-center">
                            <h3 class="mb-0">Base Camp Manager Form</h3>

                            @if (Model.TrekName != null)
                            {
                                <p>@Model.TrekName (@Convert.ToDateTime(Model.FromDate).ToString("dd-MM-yyyy") - @Convert.ToDateTime(Model.ToDate).ToString("dd-MM-yyyy")) (@Model.Batch)</p>
                            }

                            else
                            {
                                <p>No participant data available.</p>
                            }
                        </div>

                        <div class="card-body">
                            <form method="post" id="baseCampForm" enctype="multipart/form-data" asp-action="SaveEditBaseCampManagerForm" asp-controller="ViewOperationTeamDetails">
                                @if (Model.TrekName != null)
                                {

                                    <input type="hidden" name="TrekName" value="@Model.TrekName" />
                                    <input type="hidden" name="TrekId" value="@Model.TrekId" />
                                    <input type="hidden" name="DepartureId" value="@Model.DepartureId" />
                                    <input type="hidden" name="FromDate" value="@Model.FromDate" />
                                    <input type="hidden" name="ToDate" value="@Model.ToDate" />
                                    <input type="hidden" name="Batch" value="@Model.Batch" />
                                    <input type="hidden" name="FirstName" value="@Model.FirstName" />
                                    <input type="hidden" name="LastName" value="@Model.LastName" />
              @*                       <input type="hidden" as-for="Designation" value="@Model.Designation" /> *@
                                    <input type="hidden" name="Email" value="@Model.Email" />


                                }

                                <div class="col-md-4">
                                    <label class="form-label"><b>Number Of Trekker</b></label>
                                    <div class="d-flex gap-4 ms-2 bg-white rounded-2 ">
                                        <span class="text-secondary"><b>M Trekker</b></span>
                                        <span class="text-secondary"><b>F Trekker</b></span>

                                    </div>
                                    <div class="d-flex gap-2">
                                        <input type="number" class="form-control form-control-sm w-25" asp-for="MaleTrekker" />
                                        <input type="number" class="form-control form-control-sm w-25" asp-for="FemaleTrekker" />



                                    </div>
                                    <span class="text-danger"></span>
                                </div>



                                <div id="helperContainer" class="col-md-4">
                                    <label class="form-label"><b>Helper Freelancer</b></label>
                                    <div class="d-flex gap-5 ms-4 bg-white rounded-2">
                                        <span class="text-secondary"><b>Name</b></span>
                                        <span class="text-secondary"><b>Days</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>
                                    </div>
                                    <div class="helper-row d-flex gap-2">
                                        <input type="text" asp-for="HelperFreelancers[0].Name" class="form-control form-control-sm w-25" placeholder="as-for" />
                                        <input type="number" asp-for="HelperFreelancers[0].Days" class="form-control form-control-sm w-25" placeholder="Days" />
                                        <input asp-for="HelperFreelancers[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addHelper">+</button>
                                    </div>
                                </div>



                                <div id="guideContainer" class="col-md-4">
                                    <label class="form-label"><b>Guide Freelancers</</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2">
                                        <span class="text-secondary"><b>Number</b></span>
                                        <span class="text-secondary"><b>Days</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>
                                    </div>
                                    <div class="guide-row d-flex gap-2">
                                        <input type="number" asp-for="GuideFreelancers[0].Number" class="form-control form-control-sm w-25" placeholder="Number" />
                                        <input type="number" asp-for="GuideFreelancers[0].Days" class="form-control form-control-sm w-25" placeholder="Days" />
                                        <input asp-for="GuideFreelancers[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addGuide">+</button>
                                    </div>
                                </div>

                                <div id="muleContainer" class="col-md-4">
                                    <label class="form-label"><b>Mule</</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2 ">
                                        <span class="text-secondary"><b>Number</b></span>
                                        <span class="text-secondary"><b>Days</b></span>

                                    </div>
                                    <div class="mule-row d-flex gap-2">
                                        <input type="number" asp-for="Mules[0].Number" class="form-control form-control-sm w-25" placeholder="Number" />
                                        <input type="number" asp-for="Mules[0].Days" class="form-control form-control-sm w-25" placeholder="Days" />

                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addMule">+</button>
                                    </div>
                                </div>
                                <div id="portersContainer" class="col-md-4">
                                    <label class="form-label"><b>Porters</</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2">
                                        <span class="text-secondary"><b>Number</b></span>
                                        <span class="text-secondary"><b>Days</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>
                                    </div>
                                    <div class="porters-row d-flex gap-2">
                                        <input type="number" asp-for="Porters[0].Number" class="form-control form-control-sm w-25" placeholder="number" />
                                        <input type="number" asp-for="Porters[0].Days" class="form-control form-control-sm w-25" placeholder="Days" />
                                        <input asp-for="Porters[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addPorters">+</button>
                                    </div>
                                </div>



                                <div id="RoomArrivalsContainer" class="col-md-5">
                                    <label class="form-label"><b>Room Arrival</b></label>
                                    <div class="d-flex gap-5 ms-5 bg-white rounded-2">
                                        <span class="text-secondary"><b>Date</b></span>
                                        <span class="text-secondary"><b>Number</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>
                                    </div>
                                    <div class="RoomArrivals-row d-flex gap-2">

                                        <select as-for="RoomArrivals[0].Date" class="form-control form-control-sm w-25">
                                            <option value="">Select Date</option>
                                            @foreach (var date in ViewBag.AvailableDates)
                                            {
                                                <option value="@date">@date</option>
                                            }
                                        </select>
                                        <input asp-for="RoomArrivals[0].Number" type="number" class="form-control form-control-sm w-25" placeholder="Number" />
                                        <input asp-for="RoomArrivals[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addRoomArrivals"> + </button>
                                    </div>
                                    <span class="text-danger"></span>
                                </div>



                                <div id="DepartureContainer" class="col-md-5">
                                    <label class="form-label"><b>Departure</b></label>
                                    <div class="d-flex gap-5 ms-5 bg-white rounded-2">
                                        <span class="text-secondary"><b>Date</b></span>
                                        <span class="text-secondary"><b>Number</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>
                                    </div>
                                    <div class="Departure-row d-flex gap-2">
                                        <select as-for="RoomArrivalsDepartures[0].Date" class="form-control form-control-sm w-25">
                                            <option value="">Select Date</option>
                                            @foreach (var date in ViewBag.AvailableDates)
                                            {
                                                <option value="@date">@date</option>
                                            }
                                        </select>

                                        <input asp-for="RoomArrivalsDepartures[0].Number" type="number" class="form-control form-control-sm w-25" placeholder="Number" />
                                        <input asp-for="RoomArrivalsDepartures[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addDeparture"> + </button>


                                    </div>
                                    <span class="text-danger"></span>
                                </div>


                                <div class="col-md-4">
                                    <label class="form-label"><b>Offlods</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2">
                                        <span class="text-secondary"><b>Online</b></span>
                                        <span class="text-secondary"><b>Offline</b></span>

                                    </div>
                                    <div class="d-flex gap-2">
                                        <input type="number" class="form-control form-control-sm w-25" asp-for="OnlineOffloadMode" placeholder="Online" />
                                        <input type="number" class="form-control form-control-sm w-25" asp-for="OflineOffloadMode" placeholder="Offline" />



                                    </div>
                                </div>



                                <div class="col-md-4" id="MainTransportArrivalContainer">
                                    <label class="form-label"><b>Main Transport Arrival</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2">
                                        <span class="text-secondary"><b>Car No</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>

                                    </div>
                                    <div class="d-flex gap-2 MainTransportArrival-row">

                                        <input asp-for="MainTransportArrival[0].Number" type="text" class="form-control form-control-sm w-25" placeholder="Car Number" />
                                        <input asp-for="MainTransportArrival[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addMainTransportArrival"> + </button>


                                    </div>
                                    <span class="text-danger"></span>
                                </div>

                                <div class="col-md-4" id="MainTransportDepartureContainer">
                                    <label class="form-label"><b>Main Transport Departure</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2">
                                        <span class="text-secondary"><b>Car No</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>

                                    </div>
                                    <div class="d-flex gap-2 MainTransportDeparture-row">

                                        <input asp-for="MainTransportArrivalDeparture[0].Number" type="text" class="form-control form-control-sm w-25" placeholder="Car Number" />
                                        <input asp-for="MainTransportArrivalDeparture[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addMainTransportDeparture"> + </button>


                                    </div>
                                    <span class="text-danger"></span>
                                </div>



                                <div class="col-md-4" id="LocalTransportArrivalContainer">
                                    <label class="form-label"><b>Local Transport Arrival</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2">
                                        <span class="text-secondary"><b>Car No</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>

                                    </div>
                                    <div class="d-flex gap-2 LocalTransportArrival-row">

                                        <input asp-for="LocalTransportArrival[0].Number" type="text" class="form-control form-control-sm w-25" placeholder="Car Number" />
                                        <input asp-for="LocalTransportArrival[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addLocalTransportArrival"> + </button>


                                    </div>
                                    <span class="text-danger"></span>
                                </div>

                                <div class="col-md-4" id="LocalTransportDepartureContainer">
                                    <label class="form-label"><b>Local Transport Departure</b></label>
                                    <div class="d-flex gap-5 ms-3 bg-white rounded-2 ">
                                        <span class="text-secondary"><b>Car No</b></span>
                                        <span class="text-secondary"><b>Vendor</b></span>

                                    </div>
                                    <div class="d-flex gap-2 LocalTransportDeparture-row">


                                        <input asp-for="LocalTransportArrivalDeparture[0].Number" type="text" class="form-control form-control-sm w-25" placeholder="Car Number" />
                                        <input asp-for="LocalTransportArrivalDeparture[0].Vendor" type="text" class="form-control form-control-sm w-25" placeholder="Vendor" />
                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm" id="addLocalTransportDeparture"> + </button>


                                    </div>
                                    <span class="text-danger"></span>
                                </div>




                                <div class="form-group col-md-5">

                                    <label>Enter Details:</label>
                                    <textarea asp-for="TeaxtArea" class="form-control" rows="5" placeholder="Type here..."></textarea>
                                </div>


                                <div class="mt-4 col-md-4">
                                    <button type="button" class="btn btn-danger btn-sm" onclick="document.getElementById('baseCampForm').submit();">Approval</button>

                                </div>





                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






  <script>
    $(document).ready(function () {
        let helperIndex = 1;
        let guideIndex = 1;
        let muleIndex = 1;
        let portersIndex = 1;
        let roomArrivals = 1;
        let roomArrivalDeparture = 1;
        let mainTransportArrival = 1;
        let mainTransportDeparture = 1;
        let localTransportArrival = 1;
        let localTransportDeparture = 1;



        $("#addHelper").click(function () {
            let newHelper = `
                        <div class="helper-row d-flex gap-2 mt-2">
                                <input class="form-control form-control-sm w-25" asp-for="HelperFreelancers[${helperIndex}].as-for" placeholder="as-for" />
                        <input class="form-control form-control-sm w-25" asp-for="HelperFreelancers[${helperIndex}].Days" placeholder="Days" type="number" />
                                            <input class="form-control form-control-sm w-25" asp-for="HelperFreelancers[${helperIndex}].Vendor" placeholder="Vendor" />
                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                    </div>`;
            $("#helperContainer").append(newHelper);
            helperIndex++;
        });

        $("#addGuide").click(function () {
            let newGuide = `
                        <div class="guide-row d-flex gap-2 mt-2">
                                  <input class="form-control form-control-sm w-25" asp-for="GuideFreelancer[${guideIndex}].Number" placeholder="Number" />
                        <input class="form-control form-control-sm w-25" asp-for="GuideFreelancers[${guideIndex}].Days" placeholder="Days" type="number" />
                                 <input class="form-control form-control-sm w-25" asp-for="GuideFreelancers[${guideIndex}].Vendor" placeholder="Vendor" />
                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                    </div>`;
            $("#guideContainer").append(newGuide);
            guideIndex++;
        });

        $("#addMule").click(function () {
            let newMules = `
                                <div class="mule-row d-flex gap-2 mt-2">
                                   <input class="form-control form-control-sm w-25" asp-for="Mules[${muleIndex}].Number" placeholder="Number" />
                                    <input class="form-control form-control-sm w-25" asp-for="Mules[${muleIndex}].Days" placeholder="Days" type="number"/>
                                          <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                        </div>`;
            $("#muleContainer").append(newMules);
            muleIndex++;
        });

        $("#addPorters").click(function () {
            let newPorters = `
                                        <div class="porters-row d-flex gap-2 mt-2">
                                                    <input class="form-control form-control-sm w-25" asp-for="Porters[${portersIndex}].Number" placeholder="Number" />
                        <input class="form-control form-control-sm w-25" asp-for="Porters[${portersIndex}].Days" placeholder="Days" type="number" />
                        <input class="form-control form-control-sm w-25" asp-for="Porters[${portersIndex}].Vendor" placeholder="Vendor" />
                         <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                            </div>`;
            $("#portersContainer").append(newPorters);
            portersIndex++;
        });



        $("#addRoomArrivals").click(function () {
            let newRoomArrivals = `
                                            <div class="RoomArrivals-row d-flex gap-2 mt-2">


                                                              <select class="form-control form-control-sm w-25" asp-for="RoomArrivals[${roomArrivals.length}].Date >
                                                        <option value="Select Date">Select Date</option>
    @foreach (var date in ViewBag.AvailableDates)
    {
                                                                <option value="@date">@date</option>
    }
                                                </select>


                                                <input class="form-control form-control-sm w-25" asp-for="RoomArrivals[${roomArrivals}].Number" placeholder="Number" type="number" />
                                                        <input class="form-control form-control-sm w-25" asp-for="RoomArrivals[${roomArrivals}].Vendor" placeholder="Vendor"  />

                                <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                                </div>`;
            $("#RoomArrivalsContainer").append(newRoomArrivals);
            roomArrivals++;
        });

        $("#addDeparture").click(function () {
            let newDeparture = `
                                                <div class="Departure-row d-flex gap-2 mt-2">


                                                              <select class="form-control form-control-sm w-25" asp-for="RoomArrivalsDepartures[${roomArrivalDeparture.length}].Date >
                                                            <option value="Select Date">Select Date</option>
    @foreach (var date in ViewBag.AvailableDates)
    {
                                                                        <option value="@date">@date</option>
    }
                                                    </select>


                                                            <input class="form-control form-control-sm w-25" asp-for="RoomArrivalsDepartures[${roomArrivalDeparture}].Number" placeholder="Number" type="number" />
                                                                    <input class="form-control form-control-sm w-25" asp-for="RoomArrivalsDepartures[${roomArrivalDeparture}].Vendor" placeholder="Vendor" />

                                    <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                                    </div>`;
            $("#DepartureContainer").append(newDeparture);
            roomArrivalDeparture++;
        });

        $("#addMainTransportArrival").click(function () {
            let newMainTransport = `
                                                        <div class="MainTransportArrival-row d-flex gap-2 mt-2">
                                                                                   <input class="form-control form-control-sm w-25" asp-for="MainTransportArrivals[${mainTransportArrival}].Number" placeholder="Car Number" type="number" />
                                                                                    <input class="form-control form-control-sm w-25" asp-for="MainTransportArrivals[${mainTransportArrival}].Vendor" placeholder="Vendor" />

                                        <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                                        </div>`;
            $("#MainTransportArrivalContainer").append(newMainTransport);
            mainTransportArrival++;
        });

        $("#addMainTransportDeparture").click(function () {
            let newMainTransportDeparture = `
                                                        <div class="MainTransportDeparture-row d-flex gap-2 mt-2">

                                                                                           <input class="form-control form-control-sm w-25" asp-for="MainTransportDepartures[${mainTransportDeparture}].Number" placeholder="Car Number" type="number" />
                                                                                            <input class="form-control form-control-sm w-25" asp-for="MainTransportDepartures[${mainTransportDeparture}].Vendor" placeholder="Vendor" />

                                            <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                                            </div>`;
            $("#MainTransportDepartureContainer").append(newMainTransportDeparture);
            mainTransportDeparture++;
        });


        $("#addLocalTransportArrival").click(function () {
            let newLocalTransportArrival = `
                                                            <div class="LocalTransportArrival-row d-flex gap-2 mt-2">


                                                                                                <input class="form-control form-control-sm w-25" asp-for="LocalTransportArrivals[${localTransportArrival}].Number" placeholder="Car Number" type="number" />
                                                                                                        <input class="form-control form-control-sm w-25" asp-for="LocalTransportArrivals[${localTransportArrival}].Vendor" placeholder="Vendor"  />

                                                <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                                                </div>`;
            $("#LocalTransportArrivalContainer").append(newLocalTransportArrival);
            localTransportArrival++;
        });



        $("#addLocalTransportDeparture").click(function () {
            let newLocalDeparture = `
                                                                <div class="LocalTransportDeparture-row d-flex gap-2 mt-2">


                                                                                                                <input class="form-control form-control-sm w-25" asp-for="LocalTransportDepartures[${localTransportDeparture}].Number" placeholder="Car Number" type="number" />
                                                                                                                    <input class="form-control form-control-sm w-25" asp-for="LocalTransportDepartures[${localTransportDeparture}].Vendor" placeholder="Vendor" />

                                                    <button type="button" class="btn btn-danger px-1 py-0 btn-sm remove-row">-</button>
                                                    </div>`;
            $("#LocalTransportDepartureContainer").append(newLocalDeparture);
            localTransportDeparture++;
        });









        $("#baseCampForm").submit(function (e) {
            e.preventDefault();

            let formData = $(this).serialize();
            console.log(formData); // Debugging - Check data before sending

            $.ajax({
                type: "POST",
                url: "/ViewOperationTeamDetails/SaveEditBaseCampManagerForm",
                data: formData,
                success: function (response) {
                    alert("Form submitted successfully!");
                    window.location.href = "/SuccessView";
                },
                error: function (xhr, status, error) {
                    console.error(xhr.responseText);
                    alert("Error submitting form.");
                }
            });
        });
    });


    document.addEventListener('click', function (e) {
        if (e.target && e.target.classList.contains('remove-row')) {
            e.target.closest('.d-flex').remove();
        }
    });

</script>
<script>
    function toggleInput() {
        let onlineRadio = document.getElementById("online");
        let onlineNumberContainer = document.getElementById("onlineNumberContainer");
        let offlineNumberContainer = document.getElementById("offlineNumberContainer");

        if (onlineRadio.checked) {
            onlineNumberContainer.style.display = "block";
            offlineNumberContainer.style.display = "none";
        } else {
            onlineNumberContainer.style.display = "none";
            offlineNumberContainer.style.display = "block";
        }
    }

    // Initialize on page load
    window.onload = toggleInput;
</script>  