                                            Interview 4 Videos | 2 Portrait and 2 Landscape
                                        </b>
                                    </label>

                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input asp-for="InterviewVideo" class="form-check-input" type="radio" id="yes" value="yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
                                            <input asp-for="InterviewVideo" class="form-check-input" type="radio" id="yes" value="no">
