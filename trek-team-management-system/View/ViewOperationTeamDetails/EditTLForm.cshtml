                                        <label class="form-label">Google Review Count</label>
                                        <div class="d-flex gap-2">
                                            <input asp-for="GReviewCount" type="number" class="form-control form-control-sm w-25"  placeholder="review" />




                                        </div>
                                        <span class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="">
                                    <label class="form-label d-block">
                                        <b>
                                            Anything to Mentionable
                                        </b>
                                    </label>
                                    <div class="col-md-5">
                                        <label class="form-label"><b>Trekker Status</b></label>

                                        @if (ViewBag.Participants != null)
                                        {
                                            <div id="participantContainer">
                                                @for (var i = 0; i < ViewBag.Participants.Count; i++)
                                                {
                                                    var participant = ViewBag.Participants[i];
                                                    var trekkerStatus = Model?.TrekkersStatus?.FirstOrDefault(a => a.ParticipantId == participant.ParticipantId);
                                                    string statusName = trekkerStatus?.TrekkerStatus ?? "";

                                                    <div class="d-flex gap-2 mb-2">
                                                        <input type="hidden" name="TrekkersStatus[@i].ParticipantId" value="@participant.ParticipantId" />
                                                        <input type="hidden" name="TrekkersStatus[@i].FirstName" value="@participant.FirstName" />
                                                        <input type="hidden" name="TrekkersStatus[@i].LastName" value="@participant.LastName" />

                                                        <input type="text" class="form-control form-control-sm w-25"
                                                               value="@(participant.FirstName) @(participant.LastName)" readonly />

                                                        <select class="form-select form-select-sm" name="TrekkersStatus[@i].TrekkerStatus" required>
                                                            @foreach (var option in new[] {
                                                    "Summited",
                                                    "Completed, Not Summited",
                                                    "Return Halfway",
                                                    "Return from Base Camp",
                                                    "Didn't Reach Base Camp" })
                                                            {
                                                                <option value"">Choose ---</option>
                                                                <option value="@option" selected="@(statusName == option ? "selected" : null)">@option</option>
                                                            }
                                                        </select>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-info">No participants found.</div>
                                        }
                                    </div>

                                    <div class="form-group col-md-5">

                                        <label>Enter Details:</label>
                                        <textarea asp-for="TextArea" class="form-control" rows="5" placeholder="Type here..."></textarea>
                                    </div>


                                </div>



                                <div class="mt-4 col-md-4">
                                    <button type="submit" id="submitButton">Approval</button>

                                </div>



                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

