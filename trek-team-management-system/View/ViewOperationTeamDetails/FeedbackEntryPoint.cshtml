@using TTH.Areas.Super.Data.Operation_Team
@model List<AddedTeamMember>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="Feedback_form">
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="content">
                <div id="dynamicContent">
                    <div class="card shadow">
                        <div class="card-header bg-danger text-white text-center">
                            <h3 class="mb-0">Feedback Form</h3>
                        </div>
                        <div class="card-body">
                            <h2>Team Feedback Form</h2>

                           
                          

                         
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Trek Name</th>
                                            <th>Start Date</th>
                                            <th>To Date</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                      @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.TrekName</td>
                                            <td>@item.StartDate.ToString("dd-MM-yyyy")</td>
                                            <td>@item.ToDate.ToString("dd-MM-yyyy")</td>
                                            <td>
                                                <a asp-controller="ViewOperationTeamDetails"
                                                   asp-action="TLForm"
                                                   asp-route-departureId="@item.DepartureId"
                                                   asp-route-trekId="@item.TrekId"
                                                   asp-route-trekName="@item.TrekName"
                                                   asp-route-startDate="@item.StartDate.ToString("yyyy-MM-dd")"
                                                   asp-route-toDate="@item.ToDate.ToString("yyyy-MM-dd")"                                                 
                                                   asp-route-designation="@item.Designation">
                                                    TL Form
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                       



                                          
                                        }
                                    </tbody>
                                </table>
                           



                        </div> <!-- End of card-body -->
                    </div> <!-- End of card shadow -->
                </div> <!-- End of dynamicContent -->
            </div> <!-- End of content -->
        </div> <!-- End of col-md-12 -->
    </div> <!-- End of row -->
</div> <!-- End of container -->
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
