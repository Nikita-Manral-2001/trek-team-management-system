    <script>
        $(document).ready(function () {
            $("#AllTLForm").submit(function (event) {
                event.preventDefault(); // Prevent default form submission

                $.ajax({
                    url: $(this).attr("action"),
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (response) {
                        if (response.success) {
                            alert(response.message); // Show success message
                            $("#AllTLForm")[0].reset(); // Reset the form
                            $("#teamMembersContainer, #freelancingInputContainer").hide(); // Hide fields if needed
                        } else {
                            alert("Error: Could not save data."); // Handle errors
                        }
                    },
                    error: function () {
                        alert("Something went wrong! Please try again.");
                    }
                });
            });
        });
</script>

<script>
    window.removeMember = function (memberId, date, heading, designation, teamMemberName) {
        if (!confirm(`Are you sure you want to remove ${teamMemberName}?`)) {
            return;
        }

        fetch('/super/ViewOperationTeamDetails/DeleteMember', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                date: date,
                heading: heading,
                designation: designation,
               
                teamMemberName: teamMemberName,
                
               
                
            })
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log("Member deleted successfully:", data.message);
                    alert("success: " + data.message);
                    document.getElementById(memberId).remove();
                } else {
                    console.error("Error deleting member:", data.message);
                    alert("Error: " + data.message);
                }
            })
            .catch(error => {
                console.error('Fetch Error:', error);
                alert("Failed to delete member.");
            });
    };
</script>

        


 
 <script>

    document.addEventListener("DOMContentLoaded", function () {
        // Handle Edit Button Clicks
        document.querySelectorAll(".edit-btn").forEach(button => {
            button.addEventListener("click", function () {
                let heading = this.getAttribute("data-heading") || "";
                let date = this.getAttribute("data-date") || "";

                let parts = heading.split("-");

                // Remove first three elements
                let afterSecondHyphen = parts.slice(2).join("-");

                // Remove the fourth element (index 1 in this new array)

                let finalParts = afterSecondHyphen.split("-");
                let trekName = finalParts.slice(0, -1).join("-");

                console.log(trekName);



                // Ensure modal content exists before updating
                const modalContent = document.getElementById("HeadingmodalContent");
                if (modalContent) {
                    modalContent.innerHTML = `<strong>${trekName}</strong><br><strong>${date}</strong>`;
                }
                document.getElementById("headingInput").value = heading;
                document.getElementById("dateInput").value = date;
            });
        });



        document.querySelectorAll(".view-btn").forEach(button => {
            button.addEventListener("click", function () {
                let heading = this.getAttribute("data-heading") || "";
                let date = this.getAttribute("data-date") || "";

                console.log("Heading:", heading);
                console.log("Date:", date);

                if (!heading || !date) {
                    console.error("Heading or Date is missing");
                    return;
                }

                const modalContent = document.getElementById("ViewHeadingmodalContent");
                const AddedTeamMember = document.getElementById("AddedTeamMember"); // Targeting the <p> tag

                if (modalContent) {
                    let parts = heading.split("-");
                    let afterSecondHyphen = parts.slice(2).join("-");
                    let finalParts = afterSecondHyphen.split("-");
                    let trekName = finalParts.slice(0, -1).join("-");
                    modalContent.innerHTML = `<strong>${trekName} (${date})</strong>`;
                }

                document.getElementById("headingInput").value = heading;
                document.getElementById("dateInput").value = date;

                fetch('/super/ViewOperationTeamDetails/GetViewTeam', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ heading: heading, date: date })
                })
                    .then(response => response.json())
                    .then(data => {
                        console.log('Full Response from Controller:', data);

                        if (!data.success) {
                            console.error("Error in response:", data.message);
                            modalContent.innerHTML += "<p>Error fetching data.</p>";
                            return;
                        }

                        if (data.teamMembers && Array.isArray(data.teamMembers)) {
                            console.log("Extracted Team Members Array:", data.teamMembers);

                            if (data.teamMembers.length > 0) {
                                let teamDetails = data.teamMembers.map((member, index) =>
                                    `<span id="member-${index}">
                                ${member.designation} - ${member.teamMemberName}
                                <button onclick="removeMember('member-${index}', '${date}', '${heading}', '${member.designation}', '${member.teamMemberName}')"
                                    style="color: red; border: none; padding: 2px 5px; cursor: pointer; margin-left: 5px;">
                                    ❌
                                </button>
                            </span><br>`
                                ).join("");

                                console.log("Generated Team Details HTML:", teamDetails);

                                // Insert team details into the <p> tag
                                AddedTeamMember.innerHTML = teamDetails;
                            } else {
                                console.log("No valid team members found.");
                                AddedTeamMember.innerHTML = "<p>No team members available.</p>";
                            }
                        } else {
                            console.error("teamMembers is not an array:", data.teamMembers);
                            AddedTeamMember.innerHTML = "<p>Invalid response format.</p>";
                        }
                    })
                    .catch(error => {
                        console.error('Fetch Error:', error);
                        AddedTeamMember.innerHTML = "<p>Error loading team members.</p>";
                    });

            });
        });


        // selectedTeamMemberName

        // Handle Role Selection Change
        const roleDropdown = document.getElementById('myDropdown');
        
        if (roleDropdown) {
            roleDropdown.addEventListener('change', function () {
                const selectedRole = this.value;
                
                
                document.getElementById('selectedRole').value = selectedRole;
                
                const teamMembersContainer = document.getElementById('teamMembersContainer');
                const teamMembersDropdown = document.getElementById('teamMembers');
                const freelancingInputContainer = document.getElementById("freelancingInputContainer");
               
                const freelancingTextInput = document.getElementById("freelancingText");

                if (!teamMembersContainer || !teamMembersDropdown ) {
                    console.warn("Dropdown elements not found!");
                    return;
                }

                if (!selectedRole) {
                    teamMembersDropdown.innerHTML = '<option value="">Select a role first</option>';
                    teamMembersContainer.style.display = 'none';
                    return;
                }

                teamMembersContainer.style.display = 'block';
                teamMembersDropdown.innerHTML = '<option value="">Loading team members...</option>';

                fetch(`/super/ViewOperationTeamDetails/GetTeamMembers?position=${encodeURIComponent(selectedRole)}`)
      
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP error! Status: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        console.log("API Response:", data);

                        teamMembersDropdown.innerHTML = '<option value="">Select team member</option>';

                        // Check if data is an array directly
                        if (Array.isArray(data) && data.length > 0) {
                            data.forEach(member => {
                                console.log("Processing member:", member); // Log each member being processed

                                if (member && member.text) {
                                    const option = document.createElement('option');
                                    option.value = member.value; // Ensure this matches the API response
                                    option.textContent = member.text;

                                    if (member.isAssigned) {
                                        option.classList.add('assigned-member');
                                    }

                                    teamMembersDropdown.appendChild(option);
                                }
                            });
                        } else {
                            teamMembersDropdown.innerHTML = '<option value="">No team members available</option>';
                        }

                        // Adding "Freelancing" and "Fixed" options
                        const freelancingOption = document.createElement('option');
                        freelancingOption.value = 'Freelancing';
                        freelancingOption.textContent = 'Freelancing';
                        teamMembersDropdown.appendChild(freelancingOption);

                        const fixedOption = document.createElement('option');
                        fixedOption.value = 'Fixed';
                        fixedOption.textContent = 'Fixed';
                        teamMembersDropdown.appendChild(fixedOption);


                        teamMembersDropdown.addEventListener("change", function () {
                            if (this.value === "Freelancing") {
                                freelancingInputContainer.style.display = "block"; // Show input field
                            } else {
                                freelancingInputContainer.style.display = "none"; // Hide input field
                            }
                        });
                    })

                    .catch(error => {
                        console.error('Error loading team members:', error);
                        teamMembersDropdown.innerHTML = '<option value="">Error loading team members</option>';
                    });
            });
        }

        const teamMembersDropdown = document.getElementById("teamMembers");
        if (teamMembersDropdown) {
            teamMembers.addEventListener('change', function () {
                const selectedTeamMemberName = this.value;


                document.getElementById('selectedTeamMemberName').value = selectedTeamMemberName;

             

            });
        }


