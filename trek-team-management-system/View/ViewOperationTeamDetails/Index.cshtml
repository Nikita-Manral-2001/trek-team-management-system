<script>
    document.getElementById('toDate').addEventListener('change', function () {
        const fromDate = document.getElementById('fromDate').value;
        const toDate = this.value;

        if (fromDate && toDate) {
            fetch(`/super/ViewOperationTeamDetails/GetDateWiseTreks?FromDate=${fromDate}&ToDate=${toDate}`)
                .then(response => response.json())
                .then(data => {
                    const trekDropdown = document.getElementById('trekDropdown');
                    trekDropdown.innerHTML = '<option value="">-- Select Trek --</option>';

                    if (data && data.length > 0) {
                        data.forEach(trek => {
                            const option = document.createElement('option');
                            option.value = trek.value;
                            option.textContent = trek.text;
                            trekDropdown.appendChild(option);
                        });
                    } else {
                        trekDropdown.innerHTML += '<option value="">No treks found</option>';
                    }
                })
                .catch(error => console.error('Error fetching treks:', error));
        }
    });

    </script>
