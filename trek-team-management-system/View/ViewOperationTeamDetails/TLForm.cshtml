                                        <div class="form-check">
                                            <input name="SOSSignalLecture" class="form-check-input" type="radio" id="yes" value="yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
                                            <input name="SOSSignalLecture" class="form-check-input" type="radio" id="yes" value="no">
                                            <label class="form-check-label" for="no">No</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="SOSSignalLecture" class="text-danger" style="font-size:13px"></span>
