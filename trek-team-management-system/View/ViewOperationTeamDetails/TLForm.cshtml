<script>
    document.querySelectorAll('.star-rating input[type="radio"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            let ratingName = this.name;
            let ratingValue = this.value;
            document.getElementById(ratingName + 'Value').value = ratingValue;
        });
    });

    document.addEventListener("DOMContentLoaded", function () {
        const submitButton = document.getElementById("submitButton");
        const form = document.getElementById("tLForm");

        function updateRatingValue(ratingName, hiddenInputId) {
            let selectedRating = document.querySelector(`input[name="${ratingName}"]:checked`);
            if (selectedRating) {
                document.getElementById(hiddenInputId).value = selectedRating.value;
            }
        }

        if (submitButton && form) {
            submitButton.onclick = function (event) {
                event.preventDefault(); // Prevent default submission for debugging
                console.log("Form submitting..."); // Check if this appears in the console

                // Update hidden input fields with the selected rating values
                updateRatingValue("toiletRating", "toiletRatingValue");
                updateRatingValue("DiningTentRating", "DiningTentRatingValue");
                updateRatingValue("KitchenTentRating", "KitchenTentRatingValue");
                updateRatingValue("TableServingRating", "TableServingRatingValue");
                updateRatingValue("hygieneRating", "hygieneRatingValue");

                // Validate TrekkersStatus selects
                let trekkerValid = true;
                document.querySelectorAll('select[name$=".TrekkerStatus"]').forEach(function (sel) {
                    const errSpan = sel.nextElementSibling;
                    if (!sel.value || sel.value === "") {
                        if (errSpan && errSpan.classList.contains("trekker-err")) errSpan.style.display = "inline";
                        sel.classList.add("is-invalid");
                        trekkerValid = false;
                    } else {
                        if (errSpan && errSpan.classList.contains("trekker-err")) errSpan.style.display = "none";
                        sel.classList.remove("is-invalid");
                    }
                });

                if (!trekkerValid) {
                    document.querySelector('.trekker-err[style*="inline"]')
                        ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                form.submit();
            };
        } else {
            console.error("Form or submit button not found!");
        }
    });

    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".star-rating input").forEach((radio) => {
            radio.addEventListener("change", function () {
                let ratingName = this.name;
                let selectedValue = this.value;
                document.getElementById(ratingName + "Value").value = selectedValue;
            });
        });

        // Clear trekker-status errors on change
        document.querySelectorAll('select[name$=".TrekkerStatus"]').forEach(function (sel) {
            sel.addEventListener('change', function () {
                const errSpan = this.nextElementSibling;
                if (errSpan && errSpan.classList.contains("trekker-err")) errSpan.style.display = "none";
                this.classList.remove("is-invalid");
            });
        });
    });

    document.querySelectorAll('.star-rating input[type="radio"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            let ratingName = this.name;
            let ratingValue = this.value;
            // Update the hidden input value
            let hiddenInput = document.querySelector(`input[name="${ratingName}Value"]`);
            if (hiddenInput) {
                hiddenInput.value = ratingValue;
            }
        });
    });
        
</script>

