                                            <label class="form-check-label">1 = Poor, 2 = Fair, 3 = Good, 4 = Very Good, 5 = Excellent</label>
                                        </div>


                                    </div>
                                </div>

                                <div class="">
                                    <div class="d-flex flex-column gap-3">

                                      


                                        <!-- Toilet Tent Rating -->
                                        <div class="d-flex gap-4 align-items-center">
                                            <label class="form-label d-block">Toilet Tent</label>
                                            <div class="star-rating">
                                                <input type="radio" id="toilet1" name="CampManagmentRatingTL[0].toiletRating" value="5" />
                                                <label for="toilet1">&#9733;</label>

                                                <input type="radio" id="toilet2" name="CampManagmentRatingTL[0].toiletRating" value="4" />
                                                <label for="toilet2">&#9733;</label>

                                                <input type="radio" id="toilet3" name="CampManagmentRatingTL[0].toiletRating" value="3" />
                                                <label for="toilet3">&#9733;</label>

                                                <input type="radio" id="toilet4" name="CampManagmentRatingTL[0].toiletRating" value="2" />
                                                <label for="toilet4">&#9733;</label>

