                                    </label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input name="HotLunchServed" class="form-check-input" type="radio" id="yes" value="yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
                                            <input name="HotLunchServed" class="form-check-input" type="radio" id="yes" value="no">
                                            <label class="form-check-label" for="no">No</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="HotLunchServed" class="text-danger" style="font-size:13px"></span>
                                </div>

                                <div class="">
                                    <label class="form-label d-block">
                                        
                                            Hot Tea served at summit with Table
                                        
                                    </label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input name="HotTeaServed" class="form-check-input" type="radio" id="yes" value="yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
