@using TTH.Areas.Super.Models
@model TLFormViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .TL_form{
        margin-left:14%;
    }
    .star-rating {
        direction:rtl; /* Right to left for proper star alignment */
        display: flex;
        gap: 5px;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 24px;
            cursor: pointer;
            color: #ddd;
        }

        .star-rating input:checked ~ label {
            color: gold;
        }

    .d-flex {
        display: flex;
    }

    .gap-3 {
        gap: 10px;
    }

    .align-items-center {
        align-items: center;
    }

    .form-label {
        margin-bottom: 0;
    }
</style>


<div class="TL_form">
    <div class="row justify-content-center">
        <div class="col-md-12 ">
            <div class="content">
                <div id="dynamicContent">
                    <div class="card shadow">
                        <div class="card-header  bg-light text-dark text-center">
                            <h3 class="mb-0">TL Form</h3>


                            @if (ViewBag.TrekName != null)
                            {
                                <p>@ViewBag.TrekName (@Convert.ToDateTime(ViewBag.StartDate).ToString("dd-MM-yyyy") - @Convert.ToDateTime(ViewBag.ToDate).ToString("dd-MM-yyyy")) (@ViewBag.Batch)</p>
                            }

                            else
                            {
                                <p>No participant data available.</p>
                            }
                        </div>

                        <div class="card-body">
                            <form method="post" id="tLForm"  asp-action="SaveTLForm" asp-controller="ViewOperationTeamDetails">
                                @if (ViewBag.TrekName != null)
                                {

                                    <input type="hidden" name="TrekName" value="@ViewBag.TrekName" />
                                    <input type="hidden" name="TrekId" value="@ViewBag.TrekId" />
                                    <input type="hidden" name="DepartureId" value="@ViewBag.DepartureId" />
                                    <input type="hidden" name="StartDate" value="@ViewBag.StartDate" />
                                    <input type="hidden" name="EndDate" value="@ViewBag.ToDate" />
                                    <input type="hidden" name="Batch" value="@ViewBag.Batch" />
                                    <input type="hidden" name="FirstName" value="@ViewBag.FirstName" />
                                    <input type="hidden" name="LastName" value="@ViewBag.LastName" />
                                    <input type="hidden" name="Designation" value="@ViewBag.Designation" />
                                    <input type="hidden" name="Email" value="@ViewBag.Email" />
                                    <input type="hidden" name="FirstName" value="@ViewBag.FirstName" />
                                    <input type="hidden" name="LastName" value="@ViewBag.LastName" />
                                    <input type="hidden" name="id" value="@ViewBag.userId" />


                                }


                                <div class="">
                                    <label class="form-label d-block">
                                        

                                            First Day Briefing by Trek Leader
                                        
                                    </label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input name="TLBriefing" class="form-check-input" type="radio" id="Yes" value="Yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
                                            <input name="TLBriefing" class="form-check-input" type="radio" id="No" value="No">
                                            <label class="form-check-label" for="no">No</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="TLBriefing" class="text-danger" style="font-size:13px"></span>
                                </div>

                                <div class="">
                                    <label class="form-label d-block">
                                        
                                            Ams & CPR Lecture/Discussion
                                        
                                    </label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input name="AmsCPRLecture" class="form-check-input" type="radio" id="Yes" value="Yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
                                            <input name="AmsCPRLecture" class="form-check-input" type="radio" id="No" value="No">
                                            <label class="form-check-label" for="no">No</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="AmsCPRLecture" class="text-danger" style="font-size:13px"></span>
                                </div>

                                <div class="">
                                    <label class="form-label d-block">
                                        
                                            Local Flora & Fauna Lecture/Discussion
                                        
                                    </label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input name="FloraFaunaLecture" class="form-check-input" type="radio" id="yes" value="yes">
                                            <label class="form-check-label" for="yes">Yes</label>
                                        </div>

                                        <div class="form-check">
                                            <input name="FloraFaunaLecture" class="form-check-input" type="radio" id="yes" value="no">
                                            <label class="form-check-label" for="no">No</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="FloraFaunaLecture" class="text-danger" style="font-size:13px"></span>
                                </div>

                                <div class="">
                                    <label class="form-label d-block">
                                        
                                            SOS Signal Lecture/Discussion
                                        
                                    </label>
