                                <br />
                                <div>
                                    <label class="form-label d-block">
                                        
                                            Photos and videos
                                        
                                    </label>
                                    <p class="form-label d-block">2 photos and videos (max 20 sec) of each topic (Portrait and landscape)</p>
                                    <label class="form-label d-block">

                                        Briefing and Health check-up | Photos and videos | 2 Portrait and 2 Landscape

                                    </label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input name="HealthCheckupVandP" class="form-check-input" type="radio" id="yes" value="yes">
