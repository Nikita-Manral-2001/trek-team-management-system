@using TTH.Areas.Super.Models
@model ChefFormViewModel
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
<div class="Feedback_form">
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="content">
                <div id="dynamicContent">
                    <div class="card shadow">
                        <div class="card-header bg-danger text-white text-center">
                            <h3 class="mb-0">Feedback Form</h3>
                        </div>
                        <div class="card-body">
                            <h2>Team Feedback Form</h2>

                            @* User Information - Displayed Separately *@
                            @if (ViewBag.FirstName != null && ViewBag.LastName != null)
                            {
                                <div class="mb-3">
                                    <p><strong>User:</strong> @ViewBag.FirstName @ViewBag.LastName</p>
                                    <p><strong>Email:</strong> @ViewBag.UserEmail</p>
                                    <p style="background-color:#ff9999"><b>Fill the Chef form first to access the TL form. If TL is incomplete, the Chef form will be disabled until TL is submitted.</b></p>
                                </div>
                            }

                            @{
                                var trekNames = ViewBag.TrekNames as List<string>;
                                var startDates = ViewBag.StartDate as List<DateTime>;
                                var toDates = ViewBag.ToDate as List<DateTime>;
                                var designations = ViewBag.Designation as List<string>;
                                var trekIds = ViewBag.TrekId as List<int>;
                                var AlldepartureIds = ViewBag.AllDepartureIds as List<int>;
                                var Trekitinerary = ViewBag.Trekitinerary as List<string>;



                                //Chef Data

                                var ChefstartDates = ViewBag.ChefStartDate as List<DateTime>;
                                var CheftoDates = ViewBag.ChefToDate as List<DateTime>;

                                var CheftrekIds = ViewBag.ChefTrekId as List<int>;
                                var ChefAlldepartureIds = ViewBag.ChefAllDepartureIds as List<int>;

                                var chefFormDates = ViewBag.ChefFormDates as List<dynamic>;
                                var chefTrekitinerary = ViewBag.ChefTrekitinerary as List<string>;


                                //Pending Chef
                                var PendingChefTrekId = ViewBag.PendingChefTrekId as List<int>;
                                var PendingDepartureIds = ViewBag.PendingDepartureIds as List<int>;
                                var PendingChefStartDate = ViewBag.PendingChefStartDate as List<DateTime>;
                                var PendingToDate = ViewBag.PendingToDate as List<DateTime>;
                                var PendingTrekitinerary = ViewBag.PendingChefTrekitinerary as List<string>;




                            }

                            @if (trekNames != null && trekNames.Count > 0)
                            {
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Trek Name</th>
                                            <th>Start Date</th>
                                            <th>To Date</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < trekNames.Count; i++)
                                        {



                                            <tr>
                                                @if (designations[i] == "BCM" || designations[i] == "TL" || designations[i] == "Chef")
                                                {
                                                    <td>@trekNames[i]</td>
                                                    <td>@startDates[i].ToString("yyyy-MM-dd")</td>
                                                    <td>@toDates[i].ToString("yyyy-MM-dd")</td>
                                                    <td>
                                                        @if (designations[i] == "BCM")
                                                        {
                                                            <a asp-controller="ViewOperationTeamDetails"
                                                               asp-action="BaseCampManagerForm"
                                                               asp-route-departureId="@AlldepartureIds[i]"
                                                               asp-route-trekId="@trekIds[i]"
                                                               asp-route-trekName="@trekNames[i]"
                                                               asp-route-startDate="@startDates[i].ToString("yyyy-MM-dd")"
                                                               asp-route-toDate="@toDates[i].ToString("yyyy-MM-dd")"
                                                               asp-route-firstName="@ViewBag.FirstName"
                                                               asp-route-lastName="@ViewBag.LastName"
                                                               asp-route-email="@ViewBag.UserEmail"
                                                               asp-route-designation="@ViewBag.Designation"
                                                               class="btn btn-primary btn-sm feed_button">
                                                                BCM Form
                                                            </a>
                                                        }
                                                        @if (designations[i] == "TL")
                                                        {



                                                            bool isChefFormFilled = false;

                                                            if (Trekitinerary[i] == "Fixed")
                                                            {
                                                                isChefFormFilled = AlldepartureIds[i] != 0 && trekIds[i] != 0 &&
                                                                ChefAlldepartureIds.Contains(AlldepartureIds[i]) &&
                                                                CheftrekIds.Contains(trekIds[i]);
                                                            }
                                                            else if (Trekitinerary[i] == "Customize")
                                                            {
                                                                isChefFormFilled = startDates[i] != null && toDates[i] != null &&
                                                                ChefstartDates.Contains(startDates[i]) &&
                                                                CheftoDates.Contains(toDates[i]);
                                                            }

                                                            bool isChefPending = false;

                                                            if (Trekitinerary[i] == "Fixed")
                                                            {
                                                                isChefPending = (AlldepartureIds[i] != 0 && trekIds[i] != 0 &&
                                                                PendingChefTrekId.Contains(trekIds[i]) &&
                                                                PendingDepartureIds.Contains(AlldepartureIds[i]));
                                                            }
                                                            else if (Trekitinerary[i] == "Customize")
                                                            {
                                                                isChefPending = (startDates[i] != null && toDates[i] != null &&
                                                                PendingChefStartDate.Contains(startDates[i]) &&
                                                                PendingToDate.Contains(toDates[i]));
                                                            }




                                                            bool isChefInDeparture = (designations[i] == "Chef");

                                                            // Show Chef Form button if trekId and departureId match in both Pending and Chef lists
                                                            @if (isChefFormFilled || isChefPending)
                                                            {
                                                                <a asp-controller="ViewOperationTeamDetails"
                                                                   asp-action="ChefForm"
                                                                   asp-route-departureId="@AlldepartureIds[i]"
                                                                   asp-route-trekId="@trekIds[i]"
                                                                   asp-route-trekName="@trekNames[i]"
                                                                   asp-route-startDate="@startDates[i].ToString("yyyy-MM-dd")"
                                                                   asp-route-toDate="@toDates[i].ToString("yyyy-MM-dd")"
                                                                   asp-route-firstName="@ViewBag.FirstName"
                                                                   asp-route-lastName="@ViewBag.LastName"
                                                                   asp-route-email="@ViewBag.UserEmail"
                                                                   asp-route-designation="@ViewBag.Designation"
                                                                   class="btn btn-success btn-sm mt-1">
                                                                    Chef Form
                                                                </a>
                                                                <a asp-controller="ViewOperationTeamDetails"
                                                                   asp-action="TLForm"
                                                                   asp-route-departureId="@AlldepartureIds[i]"
                                                                   asp-route-trekId="@trekIds[i]"
                                                                   asp-route-trekName="@trekNames[i]"
                                                                   asp-route-startDate="@startDates[i].ToString("yyyy-MM-dd")"
                                                                   asp-route-toDate="@toDates[i].ToString("yyyy-MM-dd")"
                                                                   asp-route-firstName="@ViewBag.FirstName"
                                                                   asp-route-lastName="@ViewBag.LastName"
                                                                   asp-route-email="@ViewBag.UserEmail"
                                                                   asp-route-designation="@ViewBag.Designation"
                                                                   class="btn btn-primary btn-sm mt-1 feed_button @(isChefFormFilled || isChefInDeparture ? "" : "disabled")">
                                                                    TL Form
                                                                </a>
                                                            }


                                                            // TL Form button - Enabled only if isChefFormFilled is true
                                                            else
                                                            {
                                                                <a asp-controller="ViewOperationTeamDetails"
                                                                   asp-action="TLForm"
                                                                   asp-route-departureId="@AlldepartureIds[i]"
                                                                   asp-route-trekId="@trekIds[i]"
                                                                   asp-route-trekName="@trekNames[i]"
                                                                   asp-route-startDate="@startDates[i].ToString("yyyy-MM-dd")"
                                                                   asp-route-toDate="@toDates[i].ToString("yyyy-MM-dd")"
                                                                   asp-route-firstName="@ViewBag.FirstName"
                                                                   asp-route-lastName="@ViewBag.LastName"
                                                                   asp-route-email="@ViewBag.UserEmail"
                                                                   asp-route-designation="@ViewBag.Designation"
                                                                   class="btn btn-primary btn-sm mt-1 feed_button">
                                                                    TL Form
                                                                </a>
                                                            }



                                                        }


                                                    </td>
                                                }
                                            </tr>

                                        }
                                    </tbody>
                                </table>

                            }
                            else
                            {
                                <p>No trek details found.</p>
                            }




                        </div> <!-- End of card-body -->
                    </div> <!-- End of card shadow -->
                </div> <!-- End of dynamicContent -->
            </div> <!-- End of content -->
        </div> <!-- End of col-md-12 -->
    </div> <!-- End of row -->
</div> <!-- End of container -->
